{
  "id": "menu-and-settings",
  "title": "Menu & Device Settings",
  "steps": [
    {
      "scene": "dashboard",
      "voice": "Short tap on the screen reveals the Menu button.",
      "click": [400, 240],
      "delay": 500
    },
    {
      "scene": "dashboard_menu",
      "voice": "Top right. Tap it.",
      "highlight": { "x": 680, "y": 8, "w": 112, "h": 44 },
      "click": [738, 30],
      "delay": 1000
    },
    {
      "scene": "setup_menu",
      "voice": "Three things: Layout picker, Splash, and Device Settings.",
      "wait": 2800
    },
    {
      "voice": "Device Settings.",
      "highlight": { "x": 244, "y": 330, "w": 312, "h": 40 },
      "click": [400, 348],
      "delay": 1000
    },
    {
      "scene": "device_settings",
      "scrollSection": "top",
      "voice": "CAN Bus — bitrate and ECU preset.",
      "highlight": { "x": 30, "y": 80, "w": 370, "h": 160 },
      "wait": 3500
    },
    {
      "voice": "Device Info — serial, firmware, MAC.",
      "scrollSection": "top",
      "highlight": { "x": 400, "y": 80, "w": 370, "h": 160 },
      "wait": 3000
    },
    {
      "scrollSection": "network",
      "voice": "Network — Wi-Fi, hotspot, QR, updates.",
      "highlight": { "x": 30, "y": 80, "w": 370, "h": 240 },
      "wait": 3500
    },
    {
      "scrollSection": "display",
      "voice": "Display — brightness slider and dimmer-switch binding.",
      "highlight": { "x": 400, "y": 80, "w": 370, "h": 240 },
      "wait": 3500
    },
    {
      "scrollSection": "logging",
      "voice": "Logging, Peak Hold, and Testing — session tools.",
      "highlight": { "x": 30, "y": 80, "w": 740, "h": 100 },
      "wait": 3800
    },
    {
      "scrollSection": "can_diag",
      "voice": "CAN diagnostics — live health and a Bus Scan button.",
      "highlight": { "x": 30, "y": 80, "w": 740, "h": 160 },
      "wait": 4000
    },
    {
      "scrollSection": "footer",
      "voice": "Diagnostics, Rerun Wizard, and Factory Reset.",
      "highlight": { "x": 30, "y": 100, "w": 740, "h": 130 },
      "wait": 3800
    },
    {
      "voice": "Close returns to the dashboard.",
      "scrollSection": "top",
      "highlight": { "x": 700, "y": 28, "w": 80, "h": 36 },
      "click": [740, 42],
      "delay": 1000
    },
    {
      "scene": "dashboard",
      "voice": "Done.",
      "wait": 1800
    }
  ]
}
